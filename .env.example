DATABASE_URL="postgresql://postgres:postgres@localhost:5432/job_complaint"

JWT_SECRET="replace-with-a-strong-secret"
JWT_EXPIRES_IN="1d"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_REGION="auto"
R2_ENDPOINT=""

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_INVESTIGATION_MODEL="openai/gpt-4o"
INVITE_EMAIL_ENCRYPTION_KEY=""
SENSITIVE_DATA_TOKEN_HASH=""
CASE_FORENSIC_DEBUG_KEY=""
OUTBOX_PROCESSOR_SECRET=""
# Vercel Cron envia Authorization: Bearer <CRON_SECRET> automaticamente
CRON_SECRET=""
OUTBOX_MAX_ATTEMPTS="5"
OUTBOX_BASE_RETRY_SECONDS="20"
OUTBOX_DEFAULT_BATCH_LIMIT="20"
ABANDONMENT_WINDOW_DAYS="14"
PARTICIPANT_FOLLOWUP_DAYS="5"
PARTICIPANT_FOLLOWUP_MAX_ATTEMPTS="3"
OUTBOX_CRON_INTERVAL_SECONDS="300"
ALLOW_DEV_ROUTES="false"
TRACKING_POLLING_MS="15000"
INVITE_TOKEN_EXPIRES_HOURS="72"
APP_BASE_URL="http://localhost:3000"
MAIL_PROVIDER="ses"
# ses | cloudflare (apenas estes dois provedores)
# Amazon SES
AWS_SES_REGION=""
AWS_SES_FROM_EMAIL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Verificação antes do envio (protege reputação SES)
MAIL_VERIFY_MX="false"
MAIL_VERIFY_SES_SUPPRESSION="true"
# Webhook SNS de bounce/complaint → POST /api/internal/ses/events
SES_SNS_TOPIC_ARN=""
SES_EVENTS_SECRET=""
# Cloudflare Email (REST API)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""
CLOUDFLARE_EMAIL_FROM=""
DB_FIELD_ENCRYPTION="false"
# true em produção por padrão; false em dev para apuração legível no banco

RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_LOGIN_ATTEMPTS="10"
RATE_LIMIT_MAX_PUBLIC_REPORTS="20"
RATE_LIMIT_MAX_TOKEN_LOOKUPS="25"
RATE_LIMIT_MAX_WHISTLEBLOWER_MESSAGES="30"
RETENTION_RESOLVED_CASE_DAYS="180"
SLA_FIRST_RESPONSE_HOURS="24"
SLA_RESOLUTION_HOURS="168"
LGPD_REQUEST_SLA_DAYS="15"
